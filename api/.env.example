# Copy to .env and fill in. api/.env is gitignored.
# This file feeds the api container via docker-compose `env_file`.
# Variables consumed by docker-compose itself (POSTGRES_PASSWORD, PDC_*,
# CLOUDFLARE_TUNNEL_TOKEN) live in the repo-root .env, not here.

APP_HOST=0.0.0.0
APP_PORT=6644

# Flask debug mode. Truthy = `1`, `true`, `yes`, `on` (case-insensitive).
APP_DEBUG=

# PostgreSQL connection URI. Inside the compose network the host is
# `postgres` (the service name); from host-side scripts use `localhost`.
# Match the password to POSTGRES_PASSWORD in the root .env.
POSTGRES_URI=postgresql://hcgateway:example@postgres:5432/hcgateway

# Timezone used for /status's daily streak. UTC is the default and is
# what the moromiso pull-side worker expects. Set to e.g. `Asia/Tokyo`
# only if you also reconfigure the consumer.
STATUS_TZ=UTC

# Sentry DSN for the Flask API (optional). Leave blank to disable Sentry;
# the try/except in api/main.py makes it inert when unset. Use your own
# DSN from your Sentry project — do not reuse anyone else's.
SENTRY_DSN=
