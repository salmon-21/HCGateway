# Copy to .env and fill in. .env is gitignored.
# This file is read by `docker compose` for variable interpolation in
# docker-compose.yml. The API container also reads api/.env (separate file)
# for its Python-level config — see api/.env.example.

# PostgreSQL password used by the postgres service and (must match) the
# password embedded in POSTGRES_URI in api/.env. Leaving this unset falls
# back to "example" so a vanilla `docker compose up` boots, but pick a
# real password for any deployment you keep data in.
POSTGRES_PASSWORD=

# PostgreSQL connection URI used by host-side tools (backfill scripts,
# psql one-shots). The api/ container talks to postgres over the docker
# network and reads its own POSTGRES_URI from api/.env. Match the
# password to POSTGRES_PASSWORD above.
POSTGRES_URI=postgresql://hcgateway:example@localhost:5432/hcgateway

# Cloudflare Tunnel token for the cloudflared service (profile=tunnel).
# Create the tunnel in Cloudflare Zero Trust → Networks → Tunnels and
# copy the install-command token. Only needed if you actually want to
# expose the API over Cloudflare; otherwise leave blank and don't
# activate the `tunnel` profile.
CLOUDFLARE_TUNNEL_TOKEN=

# Grafana Cloud Private Data Connector token (pdc-agent service).
# grafana.com → Cloud Portal → Private Data Connect → Install token.
PDC_AGENT_TOKEN=

# Grafana Cloud Hosted-Grafana stack ID (numeric, e.g. 123456). Required
# by the pdc-agent service. Find it in the Cloud Portal URL or in the
# PDC install command. Leaving this committed would tie the repo to a
# specific Grafana Cloud account, so it lives in .env only.
PDC_GRAFANA_ID=

# Grafana Cloud PDC cluster, e.g. prod-us-central-0 or prod-au-southeast-1.
# Defaults to prod-au-southeast-1 in docker-compose.yml; override if your
# stack is elsewhere.
PDC_CLUSTER=
