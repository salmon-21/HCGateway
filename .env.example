# Copy to .env and fill in. .env is gitignored.

# Cloudflare Tunnel token for cloudflared service (profile=tunnel).
# Create the tunnel in Cloudflare Zero Trust → Networks → Tunnels and
# copy the install-command token.
CLOUDFLARE_TUNNEL_TOKEN=

# Grafana Cloud Private Data Connector token (pdc-agent service).
# grafana.com → Cloud Portal → Private Data Connect.
PDC_AGENT_TOKEN=

# PostgreSQL connection URI used by api/, post-process/, and backfill scripts.
# Defaults to the local docker-compose service. Backfill scripts run on the
# host and need localhost; api/post-process inside compose talk to `postgres`.
POSTGRES_URI=postgresql://hcgateway:example@localhost:5432/hcgateway
